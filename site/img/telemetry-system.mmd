flowchart LR
  %% --- Sensors -------------------------------------------------------
  subgraph SENSORS["Sensors (analog 4-20 mA + Atlas pH probe)"]
    direction TB
    S1["Well depth<br/>In-Situ"]
    S2["System pressure<br/>Dwyer"]
    S3["Chlorine tank level<br/>Banner"]
    S4["Concrete tank level<br/>Dwyer"]
    S5["pH probe<br/>Atlas Scientific"]
  end

  %% --- Pumphouse LAN ------------------------------------------------
  subgraph PUMP["Pumphouse"]
    direction TB
    COTS["MQTT–Sparkplug device"]
    BBB["BeagleBone Black industrial"]

    subgraph BBBCOL["OpenTelemetry Collector"]
      direction TB
      MQTT["self-hosted MQTT broker"]
      RX1["sparkplug receiver"]
      RX2["atlasph receiver"]
      EX1["otelarrow exporter"]
      MQTT --> RX1
      RX1 --> EX1
      RX2 --> EX1
    end

    BBB --- BBBCOL
  end

  S1 & S2 & S3 & S4 --> COTS
  COTS -- "MQTT Sparkplug B" --> MQTT
  S5 -- "I²C / UART" --> RX2

  %% --- Gateway ------------------------------------------------------
  subgraph GW["Gateway"]
    direction TB
    subgraph GWCOL["OpenTelemetry Collector"]
      direction TB
      GRX1["otelarrow receiver"]
      GRX2["prometheus receiver"]
      GEX1["jsonfile exporter"]
      GEX2["influxdb exporter"]
      GRX1 --> GEX1
      GRX1 --> GEX2
      GRX2 --> GEX1
      GRX2 --> GEX2
    end

    NFS[("NFS-mounted storage")]
    GEX1 --> NFS
  end

  EX1 == "OpenTelemetry-Arrow Protocol" ==> GRX1

  %% --- Internet boundary -------------------------------------------
  GEX2 == "HTTPS :443<br/>InfluxDB v2 write API" ==> CADDY

  %% --- Cloud --------------------------------------------------------
  subgraph CLOUD["Cloud (Linode)"]
    direction TB
    CADDY["Caddy<br/>Let's Encrypt ACME"]
    INFLUX["InfluxDB v2.x"]
    SSG["Static site"]

    CADDY -- "casparwater.us" --> SSG
    CADDY -- "influx.casparwater.us<br/>reverse_proxy" --> INFLUX
  end

  %% --- Operators ----------------------------------------------------
  OPS(["Operators / dashboards<br/>browser"])
  OPS -- "HTTPS" --> CADDY

  classDef sensor fill:#fff2cc,stroke:#c08000,color:#000
  classDef node   fill:#e8f4ff,stroke:#2b6cb0,color:#000
  classDef store  fill:#eaffea,stroke:#2f855a,color:#000
  classDef edge   fill:#f5f5f5,stroke:#666,color:#000
  class S1,S2,S3,S4,S5 sensor
  class COTS,BBB,MQTT,RX1,RX2,EX1,GRX1,GRX2,GEX1,GEX2,CADDY,INFLUX,SSG node
  class NFS store
  class OPS edge
