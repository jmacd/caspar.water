# Septic pond configuration
#
# Copy this to deploy.env and fill in your values:
#   cp deploy.env.example deploy.env
#
# deploy.env is gitignored — credentials stay local.

# Data source directory (host path for logfile-ingest)
# Staging/production: NFS mount path
# Development: local ./data/ after rsync
DATA_DIR=/data

# S3 backup configuration
S3_URL=s3://septic-dev
S3_ENDPOINT=http://watershop.casparwater.us:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ALLOW_HTTP=true

# Site generation
# Must include leading and trailing slash (e.g., /septic/).
# SITE_BASE_URL=/
