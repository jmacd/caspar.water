# Water pond configuration
#
# Copy this to deploy.env and fill in your values:
#   cp deploy.env.example deploy.env
#
# deploy.env is gitignored — credentials stay local.

# Data source directory (host path for logfile-ingest)
# Production: NFS mount or local archive path
# Development: local ./data/ after rsync from gateway
DATA_DIR=/data

# S3 backup configuration
S3_URL=s3://water-dev
S3_ENDPOINT=http://watershop.casparwater.us:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ALLOW_HTTP=true

# Site generation
# Must include leading and trailing slash (e.g., /water/).
# SITE_BASE_URL=/
