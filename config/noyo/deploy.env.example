# Noyo pond configuration
#
# Copy this to deploy.env and fill in your values:
#   cp deploy.env.example deploy.env
#
# deploy.env is gitignored — credentials stay local.

# HydroVu API credentials
# HYDRO_KEY_ID=
# HYDRO_KEY_VALUE=

# S3 backup configuration
S3_URL=s3://noyo-dev
S3_ENDPOINT=http://watershop.casparwater.us:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ALLOW_HTTP=true

# Site generation
# Must include leading and trailing slash (e.g., /noyo-harbor/).
# SITE_BASE_URL=/noyo-harbor/
