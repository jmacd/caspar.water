# Caddy configuration for watershop (staging, HTTP only - no public cert)
#
# Serves the site-staging build directly at the vhost root.

http://watershop.casparwater.us, http://:80 {
	# Selfmon dashboard rendered each tick by the watershop-selfmon
	# pond into /var/www/selfmon/<instance>/.  handle_path strips
	# /selfmon so sitegen's base_url=/selfmon/ links resolve.
	# Defaults to staging tier; the prod tier (when deployed) is
	# reachable at /selfmon/prod/.
	handle_path /selfmon/prod/* {
		root * /var/www/selfmon/watershop-selfmon-prod
		file_server
		encode zstd gzip
	}
	handle_path /selfmon/* {
		root * /var/www/selfmon/watershop-selfmon-staging
		file_server
		encode zstd gzip
	}

	root * /home/jmacd/duckpond/www/site-staging/current

	# Webserver-style JSON access log to a rolling file under
	# /var/log/caddy/. Read by the watershop-selfmon pond's
	# logfile-ingest factory (jsonlogs:// reader).
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 10
		}
		format json
	}

	file_server {
		precompressed br gzip
	}

	# Extensionless URLs: try path, then path.html, then directory
	try_files {path} {path}.html {path}/

	# Vendor assets: aggressive caching (content-addressed by sitegen)
	@vendor path /vendor/* /noyo-harbor/vendor/*
	header @vendor Cache-Control "public, max-age=31536000, immutable"

	encode zstd gzip
}
