casparwater.us {
	root * /home/jmacd/duckpond/www/current

	# Extensionless URLs: try path, then path.html, then directory
	try_files {path} {path}.html {path}/

	file_server

	# Vendor assets: aggressive caching (content-addressed by sitegen)
	@vendor path /vendor/* /noyo-harbor/vendor/*
	header @vendor Cache-Control "public, max-age=31536000, immutable"

	# Data files (parquet/.series) and pages use content-stable names
	# whose contents change on every build, so require revalidation
	# (cheap 304 via ETag/Last-Modified) to avoid serving stale data.
	@data path /data/*
	header @data Cache-Control "no-cache"

	# Compress responses
	encode zstd gzip
}

# InfluxDB v2 listens on plaintext 127.0.0.1:8087; Caddy terminates TLS
# with a Let's Encrypt cert and reverse-proxies here.  See
# terraform/station/cloud/influxdb.toml for the matching bind address.
influx.casparwater.us {
	reverse_proxy http://127.0.0.1:8087
	encode zstd gzip
}
