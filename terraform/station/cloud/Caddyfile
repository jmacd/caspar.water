casparwater.us {
	root * /home/jmacd/duckpond/www/current

	# Extensionless URLs: try path, then path.html, then directory
	try_files {path} {path}.html {path}/

	file_server

	# Vendor assets: aggressive caching (content-addressed by sitegen)
	@vendor path /vendor/* /noyo-harbor/vendor/*
	header @vendor Cache-Control "public, max-age=31536000, immutable"

	# Compress responses
	encode zstd gzip
}

# Phase 1 of the InfluxDB TLS-termination migration: terminate TLS at
# Caddy and proxy to InfluxDB's existing HTTPS listener on loopback.
# Once all clients are migrated to this hostname, Phase 2 will switch
# InfluxDB to plaintext on 127.0.0.1:8087 and drop tls_insecure_skip_verify.
influx.casparwater.us {
	reverse_proxy https://127.0.0.1:8086 {
		transport http {
			tls_insecure_skip_verify
		}
	}
	encode zstd gzip
}
